# Copy to .env and fill in. NEVER commit the real .env.

# AI provider: "ollama" (free, local, default), "openai" (any OpenAI-compatible
# endpoint — Groq/OpenRouter/Gemini free tiers, best for a zero-cost HOSTED
# deploy), "anthropic" (paid, Claude), or "mock" (canned responses, tests/CI).
AI_PROVIDER=ollama

# --- Ollama (used when AI_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# --- OpenAI-compatible free tier (used when AI_PROVIDER=openai) ---
# Server-side only, never exposed to the browser. Defaults target Groq's free
# tier (no credit card). Alternatives:
#   OpenRouter  OPENAI_BASE_URL=https://openrouter.ai/api/v1          + a :free model
#   Gemini      OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# --- Anthropic (used when AI_PROVIDER=anthropic) ---
# Server-side only, never exposed to the browser. Required only for anthropic.
ANTHROPIC_API_KEY=

# Postgres connection string used by Prisma.
# Use a NON-superuser role in production so RLS policies are enforced.
DATABASE_URL=postgresql://resume_app:resume_app_pw@127.0.0.1:5433/resume_studio

# Secret used to sign session + magic-link JWTs. Use a long random string.
AUTH_SECRET=change-me-to-a-long-random-string

# AI endpoint rate limit, requests per hour per user/IP.
RATE_LIMIT_PER_HOUR=20

# Port the backend listens on.
PORT=4000

# Origin of the frontend, used for CORS and building magic-link URLs.
FRONTEND_ORIGIN=http://localhost:5173

# Cookie settings. Set COOKIE_SECURE=true in production (HTTPS).
COOKIE_SECURE=false
